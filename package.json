{
  "name": "bunnysave-clone",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun --bun next dev -p 3000",
    "build": "bun run scripts/bun-prebuild.ts && bun --bun next build",
    "start": "bun --bun next start -p 3000",
    "lint": "next lint",
    "scrape": "python3 scripts/scrape.py",
    "parse": ".venv/bin/python scripts/parse.py",
    "db:seed": "bun --env-file-if-exists=.env.local --env-file-if-exists=.env.development.local run scripts/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "postcss": "8.5.16",
    "socks": "^2.8.9",
    "socks-proxy-agent": "^10.1.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.7.3",
    "undici": "^8.5.0"
  }
}
