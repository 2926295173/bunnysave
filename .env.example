# Public GA measurement ID (optional). Leave empty to disable analytics.
NEXT_PUBLIC_GA_ID=

# --- Database (Neon Postgres, required for auth) ---
# Either set DATABASE_URL (Vercel Neon integration) or AUTH_DB_URL.
# These are kept distinct so the deals JSON + auth DB can diverge if you want.
DATABASE_URL=
# AUTH_DB_URL=

# --- Auth (NextAuth v5) ---
# Generate with: `openssl rand -base64 32`
AUTH_SECRET=

# Google OAuth credentials (optional). Without these, the Google button
# falls back to the email login form.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Magic-link email delivery via Resend (https://resend.com). The `MAGIC_FROM`
# value must be on a domain you've verified inside Resend, otherwise the
# API rejects the request.
RESEND_API_KEY=
MAGIC_FROM="省钱兔 <admin@codestory.top>"

# --- Admin promotion ---
# Comma-separated list of emails that should be auto-promoted to admin
# role on sign-in. Useful for granting admin access without manual SQL.
ADMIN_EMAILS=gaojian292629@gmail.com

# --- Local deploy credentials (DO NOT COMMIT real values; this file is .gitignore'd) ---
# Required only when running scripts/deploy.py locally. Get your token at
# https://vercel.com/account/settings/tokens (issued tokens can be revoked there).
VERCEL_TOKEN=
VERCEL_TEAM_ID=
