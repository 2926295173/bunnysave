# Public GA measurement ID (optional). Leave empty to disable analytics.
NEXT_PUBLIC_GA_ID=

# --- Database (Neon Postgres, required for auth) ---
# Either set DATABASE_URL (Vercel Neon integration) or AUTH_DB_URL.
# These are kept distinct so the deals JSON + auth DB can diverge if you want.
DATABASE_URL=
# AUTH_DB_URL=

# --- Auth (NextAuth v5) ---
# Generate with: `openssl rand -base64 32`
AUTH_SECRET=

# Google OAuth credentials (optional). Without these, the Google button
# falls back to the email login form.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Magic-link email delivery (optional). Without Resend, the link is printed
# to the server logs for development use.
RESEND_API_KEY=
MAGIC_FROM="省钱兔 <noreply@bunnysave.com>"

# --- Admin promotion ---
# Comma-separated list of emails that should be auto-promoted to admin
# role on sign-in. Useful for granting admin access without manual SQL.
ADMIN_EMAILS=gaojian292629@gmail.com

# --- Local deploy credentials (DO NOT COMMIT real values; this file is .gitignore'd) ---
# Required only when running scripts/deploy.py locally. Get your token at
# https://vercel.com/account/settings/tokens (issued tokens can be revoked there).
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# --- Sentry (optional) ---
# When unset, the Sentry SDK is not initialized and the app runs as before.
# Generate DSNs at https://sentry.io → Project Settings → Client Keys (DSN).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Fraction of transactions to capture (0.0 – 1.0). Defaults to 0.1.
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
# Sentry auth token for uploading source maps during build. Optional.
# Must be a user-or-project token with scopes: project:releases, org:read.
# Org tokens cannot upload release artifacts (they authenticate only).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
